{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile-default",
  "description": "Storm POS Android permissions",
  "platforms": ["android"],
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-open-path",
    "sharekit:allow-share-text",
    "sharekit:allow-share-file",
    "http:allow-fetch",
    "http:allow-fetch-cancel",
    "http:allow-fetch-read-body",
    "http:allow-fetch-send",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://stormsoftware.co.za/**" }]
    }
  ],
  "remote": {
    "urls": [
      "https://stormsoftware.co.za/**",
      "https://storm-software.replit.app/**"
    ]
  }
}
